# ============================================
# 科佰支付 - 商户配置文件模板
# ============================================
# 复制此文件为 .env 并填入您的配置
# cp merchant-config.example.env .env
# ============================================

# ============================================
# 1. 服务器配置
# ============================================
# 服务端口
PORT=3000

# 运行环境: development | production
NODE_ENV=development

# 允许的跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# 2. 数据库配置
# ============================================
# SQLite数据库路径（开发环境）
DATABASE_URL=file:./kebaipay.db

# PostgreSQL配置（生产环境推荐）
# DATABASE_URL=postgresql://user:password@localhost:5432/kebaipay

# ============================================
# 3. Redis配置（可选，用于分布式锁和缓存）
# ============================================
# Redis连接地址
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================
# 4. JWT密钥配置（必须修改！）
# ============================================
# 用户JWT密钥（至少32位随机字符串）
JWT_USER_SECRET=your-random-user-secret-key-at-least-32-chars

# 管理员JWT密钥（至少32位随机字符串）
JWT_ADMIN_SECRET=your-random-admin-secret-key-at-least-32-chars

# JWT过期时间
JWT_USER_EXPIRES_IN=24h
JWT_ADMIN_EXPIRES_IN=24h

# ============================================
# 5. 数据加密密钥（必须修改！）
# ============================================
# 数据加密密钥（至少32位随机字符串）
ENCRYPTION_KEY=your-random-encryption-key-at-least-32-chars

# ============================================
# 6. 管理员配置
# ============================================
# 管理员默认密码（首次登录后请立即修改）
ADMIN_DEFAULT_PASSWORD=admin123456

# ============================================
# 7. 短信验证码配置
# ============================================
# 短信平台: aliyun | tencent | huawei | mock
# mock模式：验证码会在控制台显示，无需真实短信平台
SMS_PROVIDER=mock

# --- 阿里云短信配置 ---
# SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
# SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# SMS_SIGN_NAME=科佰支付
# SMS_TEMPLATE_CODE=SMS_123456

# --- 腾讯云短信配置 ---
# SMS_TENCENT_SECRET_ID=your-tencent-secret-id
# SMS_TENCENT_SECRET_KEY=your-tencent-secret-key
# SMS_TENCENT_SDK_APP_ID=your-sdk-app-id
# SMS_SIGN_NAME=科佰支付
# SMS_TEMPLATE_CODE=123456

# --- 华为云短信配置 ---
# SMS_HUAWEI_APP_ID=your-huawei-app-id
# SMS_HUAWEI_APP_SECRET=your-huawei-app-secret
# SMS_SIGN_NAME=科佰支付
# SMS_TEMPLATE_CODE=SMS_123456

# ============================================
# 8. 微信支付配置
# ============================================
# 微信支付商户号
# WECHAT_MCH_ID=your-mch-id

# 微信支付API密钥
# WECHAT_API_KEY=your-api-key

# 微信支付证书序列号
# WECHAT_CERT_SERIAL_NO=your-cert-serial-no

# 微信支付私钥路径
# WECHAT_PRIVATE_KEY_PATH=./certs/wechat_private_key.pem

# 微信支付平台证书路径
# WECHAT_PLATFORM_CERT_PATH=./certs/wechat_platform_cert.pem

# 微信支付AppID
# WECHAT_APP_ID=your-app-id

# ============================================
# 9. 支付宝配置
# ============================================
# 支付宝AppID
# ALIPAY_APP_ID=your-app-id

# 支付宝应用私钥
# ALIPAY_PRIVATE_KEY=your-private-key

# 支付宝公钥（或支付宝证书路径）
# ALIPAY_PUBLIC_KEY=your-public-key

# 支付宝网关地址
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ============================================
# 10. 邮件配置（可选）
# ============================================
# SMTP服务器
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-email-password
# SMTP_FROM=科佰支付 <your-email@qq.com>

# ============================================
# 11. 日志配置
# ============================================
# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# ============================================
# 12. 安全配置
# ============================================
# API限流（每分钟请求数）
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_OPEN_API=30

# 密码加密轮数
BCRYPT_SALT_ROUNDS=12
