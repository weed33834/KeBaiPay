# ============================================================================
# KeBaiPay 环境变量配置示例
# ============================================================================
# 拷贝此文件为 .env 并填入实际值：cp .env.example .env
# 严禁将 .env 提交到版本控制（已在 .gitignore 中忽略）。
#
# 部署方式：
#   1) Docker Compose  → DATABASE_URL / REDIS_URL 由 docker-compose.yml 注入，
#      本地 .env 只需填下面 secret 项即可（其他变量 compose 文件里有默认值）。
#   2) 裸机 Node 部署  → 需要把 DATABASE_URL / REDIS_URL 改成实际地址。
#
# 生产环境校验：
#   - SecurityValidatorService 会拒绝使用默认/弱密钥启动（NODE_ENV=production）
#   - env-validation.ts 在启动时强制校验必需变量与协议格式
# ============================================================================

# ============================================================================
# 一、必须修改的配置项（生产环境 SecurityValidator 强校验）
# ============================================================================

# PostgreSQL 密码（docker compose 模式必须设置）
POSTGRES_PASSWORD="change-postgres-password-in-production"

# JWT 密钥（32 字符以上，含大小写+数字，USER 与 ADMIN 必须不同）
JWT_USER_SECRET="change-user-secret-in-production-32chars"
JWT_ADMIN_SECRET="change-admin-secret-in-production-32chars"

# JWT 过期时间（默认 1h，可按需调整）
#JWT_USER_EXPIRES_IN="2h"
#JWT_ADMIN_EXPIRES_IN="1h"

# Admin 初始密码（8 字符以上，含大小写+数字；首次启动 seed 时使用）
ADMIN_DEFAULT_PASSWORD="ChangeAdmin2026"

# AES 加密密钥（32 字符以上；用于身份证、银行卡等敏感字段 AES-256-GCM 加密）
ENCRYPTION_KEY="change-encryption-key-in-production-32chars"

# Redis 密码（生产环境必填，资金操作的并发安全靠 Redis 分布式锁）
REDIS_PASSWORD="change-redis-password-in-production"

# ============================================================================
# 二、数据库（PostgreSQL）
# ============================================================================

# 裸机部署需要；docker compose 模式自动注入
POSTGRES_USER="postgres"
POSTGRES_DB="kebaipay"

# 裸机部署时把 POSTGRES_PASSWORD 替换为实际密码，并同步到 DATABASE_URL
DATABASE_URL="postgresql://postgres:change-postgres-password-in-production@localhost:5432/kebaipay?schema=public"

# PostgreSQL 连接池调优（多副本部署时按 PG max_connections / 副本数 调整）
DATABASE_CONNECTION_LIMIT=5        # 单进程最大连接数，默认 5
DATABASE_STATEMENT_TIMEOUT_MS=30000   # 单条 SQL 执行超时（毫秒），默认 30000
DATABASE_POOL_TIMEOUT_SEC=10       # 连接池获取超时（秒），默认 10

# ============================================================================
# 三、Redis（生产环境必填，分布式锁 / 防重放 / 滑动窗口限流）
# ============================================================================

REDIS_URL="redis://localhost:6379"
# 带密码的连接串示例：redis://:your-password@redis-host:6379/0

# ============================================================================
# 四、Server
# ============================================================================

PORT=3000
NODE_ENV="production"

# CORS 允许的跨域来源（逗号分隔，生产环境必须改成你的域名）
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# ============================================================================
# 五、支付渠道与回调
# ============================================================================

# 充值/支付回调通知地址（生产环境必须改成 https）
RECHARGE_NOTIFY_URL="http://localhost:3000/webhooks/recharge"

# Mock 渠道签名密钥（仅开发/测试使用，生产环境 SecurityValidator 拒绝启动 mock 渠道）
MOCK_CHANNEL_SECRET="change-mock-secret-in-dev"

# 收银台对外地址（用于回跳商户页）
CASHIER_BASE_URL="http://localhost:3000"

# ---- 支付宝渠道（可选）----
# 支付宝应用 AppId
ALIPAY_APP_ID=""
# 应用私钥（PKCS8）
ALIPAY_APP_PRIVATE_KEY=""
# 支付宝公钥
ALIPAY_PUBLIC_KEY=""
# 回调地址
ALIPAY_NOTIFY_URL="https://your-domain.com/webhooks/alipay"

# ---- 微信支付渠道（可选）----
# 商户号
WECHAT_PAY_MCH_ID=""
# 商户 API V3 密钥
WECHAT_PAY_API_V3_KEY=""
# 商户私钥（apiclient_key.pem 内容）
WECHAT_PAY_PRIVATE_KEY=""
# 商户证书序列号
WECHAT_PAY_CERT_SERIAL_NO=""
# 回调地址
WECHAT_PAY_NOTIFY_URL="https://your-domain.com/webhooks/wechat"

# ============================================================================
# 六、SMS 短信服务（验证码 / 通知）
# ============================================================================
# provider 可选：aliyun / tencent / huawei / mock（生产环境禁止 mock）
# 接入步骤详见 docs/sms-integration.md
SMS_PROVIDER="mock"
SMS_SIGN_NAME="科佰支付"
SMS_TEMPLATE_CODE=""

# 阿里云短信
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""

# 腾讯云短信（控制台获取 SmsSdkAppId）
SMS_TENCENT_SECRET_ID=""
SMS_TENCENT_SECRET_KEY=""
SMS_TENCENT_SDK_APP_ID=""

# 华为云短信
SMS_HUAWEI_APP_ID=""
SMS_HUAWEI_APP_SECRET=""
SMS_HUAWEI_SENDER=""
SMS_HUAWEI_CHANNEL="sms"
# 华为云短信 API 端点（区域相关，默认 cn-north-4）
SMS_HUAWEI_ENDPOINT="smsapi.cn-north-4.myhuaweicloud.com"

# ============================================================================
# 七、邮件（SMTP）通知（可选，未配置 SMTP_USER 时邮件通知自动降级为日志）
# ============================================================================
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="KeBaiPay <noreply@kebaipay.com>"

# ============================================================================
# 八、可观测性（OpenTelemetry / Prometheus / Sentry，可选）
# ============================================================================
# 配置后启动 OTLP HTTP 导出，未配置时为零开销 no-op
OTEL_SERVICE_NAME="kebaipay"
OTEL_EXPORTER_OTLP_ENDPOINT=""
#OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer ..."

# Prometheus 指标端点：GET /metrics（默认开启）
# Sentry 异常告警：未配置 SDK_DSN 时不启用
SENTRY_DSN=""

# ============================================================================
# 九、限流（Throttler 默认配置已硬编码在 app.module.ts，如需覆盖可在此扩展）
# ============================================================================
# THROTTLER_TTL=60000
# THROTTLER_LIMIT=100
