# ===========================================
# KeBaiPay Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
#
# 部署方式两种：
#   1) docker compose up -d  → DATABASE_URL / REDIS_URL 由 docker-compose.yml 注入，
#      本地 .env 只需要填下面 secret 项即可（其他变量 compose 文件里有默认值）。
#   2) 裸机 Node 部署         → 还需要把 DATABASE_URL / REDIS_URL 改成实际地址。

# ====================================================================
# 必须修改的配置项（SecurityValidator 强校验，留默认值生产环境会拒绝启动）
# ====================================================================

# ---- PostgreSQL 密码（docker compose 模式必须设置）----
POSTGRES_PASSWORD="change-postgres-password-in-production"

# ---- JWT secrets（32 字符以上，含大小写+数字）----
JWT_USER_SECRET="change-user-secret-in-production-32chars"
JWT_ADMIN_SECRET="change-admin-secret-in-production-32chars"

# ---- Admin 初始密码（8 字符以上，含大小写+数字）----
ADMIN_DEFAULT_PASSWORD="ChangeAdmin2026"

# ---- AES 加密密钥（32 字符以上）----
ENCRYPTION_KEY="change-encryption-key-in-production-32chars"

# ---- Redis 密码 ----
REDIS_PASSWORD="change-redis-password-in-production"

# ====================================================================
# 以下项目按需修改
# ====================================================================

# ---- PostgreSQL（裸机部署需要，docker compose 模式自动注入）----
POSTGRES_USER="postgres"
POSTGRES_DB="kebaipay"
# 裸机部署时把 POSTGRES_PASSWORD 替换为实际密码，并同步到 DATABASE_URL
DATABASE_URL="postgresql://postgres:change-postgres-password-in-production@localhost:5432/kebaipay?schema=public"

# PostgreSQL 连接池调优（多副本部署时按 PG max_connections / 副本数 调整）
# 单进程最大连接数，默认 5
DATABASE_CONNECTION_LIMIT=5
# 单条 SQL 执行超时（毫秒），超时 PG 主动取消查询，默认 30000
DATABASE_STATEMENT_TIMEOUT_MS=30000
# 从连接池获取连接的等待超时（秒），超时快速失败，默认 10
DATABASE_POOL_TIMEOUT_SEC=10

# ---- Redis（裸机部署需要，docker compose 模式自动注入）----
REDIS_URL="redis://localhost:6379"

# ---- CORS（改成你的真实域名，逗号分隔）----
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# ---- Server ----
PORT=3000
NODE_ENV="production"

# ---- Payment Channels ----
RECHARGE_NOTIFY_URL="http://localhost:3000/webhooks/recharge"
# Mock 渠道签名密钥：仅开发/测试环境使用，生产环境必须禁用 mock 渠道
MOCK_CHANNEL_SECRET="change-mock-secret-in-dev"

# ---- Cashier ----
CASHIER_BASE_URL="http://localhost:3000"
